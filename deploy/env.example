# SEU-Monitor 环境变量配置
# 复制本文件为 .env，填入实际值：
#   cp deploy/env.example .env

# ----- 路径 -----
MONITOR_CONFIG=/home/ubuntu/SEU-Monitor/config/sites.yaml
STORE_ROOT=/home/ubuntu/SEU-Monitor/store
SNAPSHOT_ROOT=/home/ubuntu/seu-snapshots

# ----- 通知 -----
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook

# ----- 代理 (aTrust tinyproxy) -----
HTTP_PROXY=http://127.0.0.1:8888
HTTPS_PROXY=http://127.0.0.1:8888

# ----- VPN 健康检查 -----
VPN_CHECK_URL=https://cvs.seu.edu.cn
VPN_ENABLED=true
VPN_REQUIRED=true
VPN_FAIL_FAST=true

# ----- 网络 -----
REQUEST_TIMEOUT=20

# ----- aTrust 自动登录 (Playwright) -----
# 统一认证账号密码（禁止写入代码、禁止打印到日志、禁止进入飞书消息）
ATRUST_USERNAME=your_student_id
ATRUST_PASSWORD=your_password
# Playwright 持久化用户数据目录（默认）
ATRUST_USER_DATA_DIR=/home/ubuntu/.cache/seu-monitor/atrust-playwright
# 登录失败时是否截图（截图可能包含敏感信息）
ATRUST_SCREENSHOT_ON_FAIL=true

# ----- 定时任务 -----
# 如果使用 crontab，请将上述环境变量也写入 crontab 文件
